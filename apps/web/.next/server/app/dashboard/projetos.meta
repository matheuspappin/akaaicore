{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/projetos/layout,_N_T_/dashboard/projetos/page,_N_T_/dashboard/projetos"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/projetos/__PAGE__",
    "/dashboard/projetos",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}